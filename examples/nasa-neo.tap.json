{
  "version": 1,
  "name": "nasa-neo",
  "source": {
    "format": "json",
    "location": {
      "via": "path",
      "ref": "/Fast/Shared/workspaces/mpp-hackathon-project/examples/neo-asteroids.json"
    },
    "authEnv": null,
    "contract": {
      "determinism": "deterministic",
      "freshnessWindow": "24h"
    }
  },
  "schema": [
    {
      "name": "name",
      "type": "string",
      "required": false
    },
    {
      "name": "absolute_magnitude_h",
      "type": "number",
      "required": false
    },
    {
      "name": "estimated_diameter_min_m",
      "type": "number",
      "required": false
    },
    {
      "name": "estimated_diameter_max_m",
      "type": "number",
      "required": false
    },
    {
      "name": "is_potentially_hazardous",
      "type": "boolean",
      "required": false
    },
    {
      "name": "close_approach_date",
      "type": "timestamp",
      "required": false
    },
    {
      "name": "relative_velocity_kph",
      "type": "number",
      "required": false
    },
    {
      "name": "miss_distance_km",
      "type": "number",
      "required": false
    },
    {
      "name": "miss_distance_lunar",
      "type": "number",
      "required": false
    },
    {
      "name": "orbiting_body",
      "type": "string",
      "required": false
    }
  ],
  "query": {
    "filters": [
      {
        "field": "name",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "absolute_magnitude_h",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "estimated_diameter_min_m",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "estimated_diameter_max_m",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "is_potentially_hazardous",
        "ops": ["eq", "ne"]
      },
      {
        "field": "close_approach_date",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte"]
      },
      {
        "field": "relative_velocity_kph",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "miss_distance_km",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "miss_distance_lunar",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "orbiting_body",
        "ops": ["eq", "ne", "in", "like"]
      }
    ],
    "selectable": "*",
    "sortable": [
      "name",
      "absolute_magnitude_h",
      "estimated_diameter_min_m",
      "estimated_diameter_max_m",
      "is_potentially_hazardous",
      "close_approach_date",
      "relative_velocity_kph",
      "miss_distance_km",
      "miss_distance_lunar",
      "orbiting_body"
    ],
    "maxLimit": 1000,
    "defaultLimit": 100
  },
  "pricing": {
    "unit": "row",
    "unitDefinition": "one row of nasa-neo",
    "unitPrice": "0.0001",
    "currency": "0x20c0000000000000000000000000000000000000"
  },
  "cache": {
    "key": "queryHash",
    "ttl": "1h"
  },
  "evals": {
    "golden": [
      {
        "request": {
          "limit": 1000
        },
        "expectRowCount": 41
      }
    ],
    "invariants": [],
    "sampleSize": 20
  },
  "mpp": {
    "intent": "session",
    "recipient": "0x000000000000000000000000000000000000dEaD",
    "currency": "0x20c0000000000000000000000000000000000000",
    "feePayer": true
  }
}
