{
  "version": 1,
  "name": "exoplanets",
  "source": {
    "format": "csv",
    "location": {
      "via": "url",
      "ref": "https://exoplanetarchive.ipac.caltech.edu/TAP/sync?query=SELECT%20pl_name%20as%20name%2C%20hostname%20as%20host_star%2C%20CAST%28disc_year%20AS%20INTEGER%29%20as%20discovery_year%2C%20discoverymethod%20as%20method%2C%20sy_dist%20as%20distance_pc%2C%20pl_orbper%20as%20period_days%2C%20pl_rade%20as%20radius_earth%2C%20pl_bmasse%20as%20mass_earth%2C%20pl_eqt%20as%20eq_temp_k%20FROM%20pscomppars%20WHERE%20pl_rade%20is%20not%20null%20and%20sy_dist%20is%20not%20null&format=csv"
    },
    "authEnv": null,
    "contract": {
      "determinism": "deterministic",
      "freshnessWindow": "24h"
    }
  },
  "schema": [
    {
      "name": "name",
      "type": "string",
      "required": false
    },
    {
      "name": "host_star",
      "type": "string",
      "required": false
    },
    {
      "name": "discovery_year",
      "type": "number",
      "required": false
    },
    {
      "name": "method",
      "type": "string",
      "required": false
    },
    {
      "name": "distance_pc",
      "type": "number",
      "required": false
    },
    {
      "name": "period_days",
      "type": "number",
      "required": false
    },
    {
      "name": "radius_earth",
      "type": "number",
      "required": false
    },
    {
      "name": "mass_earth",
      "type": "number",
      "required": false
    },
    {
      "name": "eq_temp_k",
      "type": "number",
      "required": false
    }
  ],
  "query": {
    "filters": [
      {
        "field": "name",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "host_star",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "discovery_year",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "method",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "distance_pc",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "period_days",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "radius_earth",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "mass_earth",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "eq_temp_k",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      }
    ],
    "selectable": "*",
    "sortable": [
      "name",
      "host_star",
      "discovery_year",
      "method",
      "distance_pc",
      "period_days",
      "radius_earth",
      "mass_earth",
      "eq_temp_k"
    ],
    "maxLimit": 1000,
    "defaultLimit": 100
  },
  "pricing": {
    "unit": "row",
    "unitDefinition": "one row of exoplanets",
    "unitPrice": "0.0001",
    "currency": "0x20c0000000000000000000000000000000000000"
  },
  "cache": {
    "key": "queryHash",
    "ttl": "1h"
  },
  "evals": {
    "golden": [
      {
        "request": {
          "limit": 1000
        },
        "expectRowCount": 1000
      }
    ],
    "invariants": [],
    "sampleSize": 20
  },
  "mpp": {
    "intent": "session",
    "recipient": "0x000000000000000000000000000000000000dEaD",
    "currency": "0x20c0000000000000000000000000000000000000",
    "feePayer": true
  }
}
