    {
      "name": "nst",
      "type": "integer",
      "required": false
    },
    {
      "name": "gap",
      "type": "integer",
      "required": false
    },
    {
      "name": "dmin",
      "type": "number",
      "required": false
    },
    {
      "name": "rms",
      "type": "number",
      "required": false
    },
    {
      "name": "net",
      "type": "string",
      "required": false
    },
    {
      "name": "id",
      "type": "string",
      "required": false
    },
    {
      "name": "updated",
      "type": "timestamp",
      "required": false
    },
    {
      "name": "place",
      "type": "string",
      "required": false
    },
    {
      "name": "type",
      "type": "string",
      "required": false
    },
    {
      "name": "horizontalError",
      "type": "number",
      "required": false
    },
    {
      "name": "depthError",
      "type": "number",
      "required": false
    },
    {
      "name": "magError",
      "type": "number",
      "required": false
    },
    {
      "name": "magNst",
      "type": "integer",
      "required": false
