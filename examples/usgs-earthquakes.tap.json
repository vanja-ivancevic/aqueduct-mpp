        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "locationSource",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "magSource",
        "ops": ["eq", "ne", "in", "like"]
      }
