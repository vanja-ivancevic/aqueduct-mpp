      "type": "timestamp",
      "required": false
    },
    {
      "name": "latitude",
      "type": "number",
      "required": false
    },
    {
      "name": "longitude",
      "type": "number",
      "required": false
    },
    {
      "name": "depth",
      "type": "number",
      "required": false
    },
    {
      "name": "mag",
      "type": "number",
      "required": false
    },
    {
      "name": "magType",
      "type": "string",
      "required": false
