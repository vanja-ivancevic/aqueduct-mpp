      },
      {
        "field": "rms",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "net",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "id",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "updated",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte"]
      },
      {
        "field": "place",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "type",
        "ops": ["eq", "ne", "in", "like"]
      },
      {
        "field": "horizontalError",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "depthError",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "magError",
        "ops": ["eq", "ne", "lt", "lte", "gt", "gte", "in"]
      },
      {
        "field": "magNst",
